{
  "name": "bartonic",
  "version": "2.0.0",
  "description": "BART real-time schedule, favorites & map — PWA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/generate-icons.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:live": "LIVE_VALIDATE=1 vitest run src/test/live-audit.test.ts",
    "test:live:all": "node scripts/live-audit-all.mjs"
  },
  "dependencies": {
    "gtfs-realtime-bindings": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "serialize-javascript": "7.0.4"
  }
}
